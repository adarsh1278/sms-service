{
  "name": "sms-bridge",
  "version": "0.1.1",
  "description": "Send SMS from Node.js using your Android phone over local network (no external SMS APIs)",
  "author": "Adarsh Tiwari",
  "contributors": [
    "Yashvant Yadav"
  ],
  "type": "module",
  "preferGlobal": true,
  "files": [
    "bin",
    "src",
    "README.md",
    "RUNNING.md"
  ],
  "bin": {
    "sms-bridge": "bin/cli.js",
    "sms": "bin/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adarsh1278/sms-service.git"
  },
  "homepage": "https://github.com/adarsh1278/sms-service",
  "bugs": {
    "url": "https://github.com/adarsh1278/sms-service/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node ./bin/cli.js",
    "connect": "node ./bin/cli.js connect",
    "status": "node ./bin/cli.js status",
    "test": "node --test",
    "mock": "node ./mock-android/mock-server.js"
  },
  "keywords": [
    "sms",
    "nodejs",
    "android",
    "cli",
    "mdns",
    "bonjour",
    "local-network",
    "sms-api",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bonjour": "^3.5.0"
  },
  "devDependencies": {
    "express": "^4.21.2"
  }
}
